# Copiar este archivo a ".env" y completar los valores reales.
# El archivo ".env" NUNCA debe subirse al control de versiones (ya está en .gitignore).

# Secreto usado para firmar la cookie de sesión. OBLIGATORIO en producción.
# Generarlo una sola vez con:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Si no se define, la app genera uno aleatorio y lo guarda en .session_secret
# (solo recomendado para desarrollo, no para producción ni para entornos
# con más de una instancia del proceso).
SIGEMEP_SESSION_SECRET=

# Carpeta donde están los PDF de memorandos. Opcional: si no se define, se usa
# el valor por defecto de config.py (distinto en Windows y Linux).
SIGEMEP_PDF_DIR=

# Carpeta donde están los archivos reservados. Opcional, mismo criterio que arriba.
SIGEMEP_RESERVADOS_DIR=

# Poner en 1 SOLO si el servidor queda detrás de un proxy/balanceador con
# HTTPS (nginx, Caddy, etc.). Hace que la cookie de sesión lleve el flag
# "Secure" y por lo tanto no viaje por HTTP plano. Si se activa sin HTTPS
# real delante, el navegador nunca va a aceptar/enviar la cookie y nadie
# podrá loguearse.
SIGEMEP_COOKIE_SECURE=0
